# ABOUTME: Example quadlet container unit for edookit summary gatherer.
# ABOUTME: Copy and adapt for your deployment. See README.md for details.
#
# Installation:
#   1. Copy this file and edookit2summary.timer to your quadlet directory
#   2. Adjust Volume path, Network, and EnvironmentFile for your system
#   3. Place cookies.json in the host directory mapped to /data
#   4. Create the environment file with Azure/SMTP config (see README.md)
#   5. Run: systemctl --user daemon-reload
#   6. Enable the timer: systemctl --user enable --now edookit2summary.timer
#
# Monitoring:
#   systemctl --user status edookit2summary
#   journalctl --user -u edookit2summary --no-pager -n 50

[Unit]
Description=Edookit school notification summary

[Container]
Image=ghcr.io/bexelbie/edookit2summary:latest
ContainerName=edookit2summary
PodmanArgs=--pull=newer

# Host directory is mounted as /data inside the container.
# cookies.json lives here (edookit session cookies only).
Volume=/home/youruser/edookit2summary:/data:Z

# Static config: Azure OpenAI and SMTP settings.
# Deliver via 1Password/op or a plain env file with key=value lines.
# Required vars: AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_KEY,
#   AZURE_OPENAI_DEPLOYMENT, AZURE_OPENAI_API_VERSION,
#   SMTP_HOST, SMTP_PORT, EMAIL_FROM, EMAIL_TO
EnvironmentFile=/home/youruser/edookit2summary/edookit2summary.env

# Set this to your Podman network that can reach the SMTP server
Network=YOUR-NETWORK-NAME

[Service]
Type=oneshot
Restart=no
StandardOutput=journal
StandardError=journal
