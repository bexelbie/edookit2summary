# LLM: Gemini (tried first when both are configured)
# GEMINI_API_KEY=YOUR-GEMINI-KEY
# GEMINI_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-3.1-pro-preview

# LLM: Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=YOUR-API-KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-nano
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# LLM retry (cycles across all configured providers before giving up)
# LLM_MAX_RETRIES=3

# Translation target language
# TARGET_LANGUAGE=English

# Max updates to process per run
# MAX_UPDATES=50

# SMTP email delivery
SMTP_HOST=maddy
SMTP_PORT=25
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com

